<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Painel Admin - Delivery Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 p-4">

<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold text-center mb-8">⚙️ Painel de Controle</h1>

    <!-- ABAS -->
    <div class="flex flex-wrap gap-2 mb-6 border-b pb-4">
        <button onclick="aba('config')" class="aba-btn bg-blue-600 text-white px-4 py-2 rounded">Configurações</button>
        <button onclick="aba('produtos')" class="aba-btn bg-gray-200 px-4 py-2 rounded">Produtos</button>
        <button onclick="aba('anuncios')" class="aba-btn bg-gray-200 px-4 py-2 rounded">Anúncios</button>
    </div>

    <!-- CONTEUDO DINAMICO -->
    <div id="conteudo-admin"></div>

</div>

<script>
let config = {};
let produtos = [];
let abaAtiva = 'config';

// CARREGA DADOS
function carregar() {
    fetch('config.json').then(res => res.json()).then(d => config = d);
    fetch('products.json').then(res => res.json()).then(d => produtos = d);
    setTimeout(() => renderizar(), 100);
}

// TROCA DE ABA
function aba(nome) {
    abaAtiva = nome;
    document.querySelectorAll('.aba-btn').forEach((b, i) => {
        b.className = i == nome ? 'bg-blue-600 text-white px-4 py-2 rounded' : 'bg-gray-200 px-4 py-2 rounded';
    });
    renderizar();
}

// RENDERIZA TELA
function renderizar() {
    const el = document.getElementById('conteudo-admin');
    
    if(abaAtiva == 'config') {
        el.innerHTML = `
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-xl font-bold mb-4">🎨 Personalização da Loja</h2>
                
                <label>Nome da Loja:</label>
                <input id="nome_loja" value="${config.nome_loja}" class="w-full border p-2 rounded mb-4">

                <label>Cor Primária (Menu, Botoes):</label>
                <input type="color" id="cor1" value="${config.cores.primaria}" class="w-full h-10 mb-2">
                
                <label>Cor Secundária (Ações, WhatsApp):</label>
                <input type="color" id="cor2" value="${config.cores.secundaria}" class="w-full h-10 mb-2">

                <label>Cor de Fundo:</label>
                <input type="color" id="cor3" value="${config.cores.fundo}" class="w-full h-10 mb-4">

                <button onclick="salvarConfig()" class="bg-green-600 text-white px-6 py-3 rounded font-bold">
                    <i class="fas fa-save"></i> Salvar Configurações
                </button>

                <div class="mt-6 p-4 bg-gray-900 text-green-400 rounded">
                    <p class="mb-2">📋 Copie o código abaixo e cole no config.json:</p>
                    <textarea id="code_config" class="w-full h-40 p-2 font-mono text-sm"></textarea>
                    <button onclick="copiar('code_config')" class="mt-2 bg-blue-500 text-white px-4 py-1 rounded">Copiar</button>
                </div>
            </div>
        `;
    }

    if(abaAtiva == 'produtos') {
        let htmlProdutos = produtos.map((p, i) => `
            <div class="border p-3 rounded flex justify-between items-center">
                <span>${p.nome} (${p.categoria})</span>
                <div>
                    <button onclick="editarProduto(${i})" class="text-blue-500 mr-2">Editar</button>
                    <button onclick="excluirProduto(${i})" class="text-red-500">Excluir</button>
                </div>
            </div>
        `).join('');

        el.innerHTML = `
            <div class="grid md:grid-cols-2 gap-6">
                <!-- FORM -->
                <div class="bg-white p-6 rounded-xl shadow">
                    <h2 class="text-xl font-bold mb-4">➕ Adicionar / Editar Produto</h2>
                    
                    <input id="p_nome" placeholder="Nome" class="w-full border p-2 mb-2">
                    <input id="p_desc" placeholder="Descrição" class="w-full border p-2 mb-2">
                    <input id="p_preco" type="number" step="0.01" placeholder="Preço" class="w-full border p-2 mb-2">
                    <input id="p_cat" placeholder="Categoria (ex: Lanches, Pizza)" class="w-full border p-2 mb-2">
                    <input id="p_img" placeholder="URL da Imagem" class="w-full border p-2 mb-4">

                    <hr class="my-4">
                    <h3 class="font-bold">🍕 Opções de Sabores (Para Pizza)</h3>
                    <p class="text-sm text-gray-500 mb-2">Deixe vazio se não for pizza.</p>
                    <div id="area_sabores"></div>
                    <button onclick="addSabor()" class="text-sm bg-blue-100 px-2 py-1 rounded mb-4">+ Adicionar Sabor</button>

                    <hr class="my-4">
                    <h3 class="font-bold">🎟️ Adicionais / Acompanhamentos</h3>
                    <input id="p_maxadic" type="number" placeholder="Quantidade máxima (ex: 3)" class="w-full border p-2 mb-2">
                    <div id="area_adicionais"></div>
                    <button onclick="addAdic()" class="text-sm bg-blue-100 px-2 py-1 rounded mb-4">+ Adicionar Item</button>

                    <button onclick="salvarProduto()" class="w-full bg-green-600 text-white py-3 rounded font-bold">Salvar Produto</button>
                </div>

                <!-- LISTA -->
                <div class="bg-white p-6 rounded-xl shadow">
                    <h2 class="text-xl font-bold mb-4">📋 Produtos Cadastrados</h2>
                    <div class="space-y-2">${htmlProdutos}</div>

                    <div class="mt-6 p-4 bg-gray-900 text-green-400 rounded">
                        <p class="mb-2">📋 Código do products.json:</p>
                        <textarea id="code_prod" class="w-full h-40 p-2 font-mono text-sm"></textarea>
                        <button onclick="copiar('code_prod')" class="mt-2 bg-blue-500 text-white px-4 py-1 rounded">Copiar</button>
                    </div>
                </div>
            </div>
        `;
        atualizarCodigoProdutos();
    }

    if(abaAtiva == 'anuncios') {
         el.innerHTML = `
            <div class="bg-white p-6 rounded-xl shadow">
                <h2 class="text-xl font-bold mb-4">📢 Gerenciar Anúncios / Banners</h2>
                ${config.anuncios.map((a, i) => `
                    <div class="border p-4 rounded mb-4">
                        <input value="${a.titulo}" id="ad_titulo${i}" placeholder="Título" class="w-full border p-2 mb-2">
                        <input value="${a.subtitulo}" id="ad_sub${i}" placeholder="Subtítulo" class="w-full border p-2 mb-2">
                        <input value="${a.imagem}" id="ad_img${i}" placeholder="URL da Imagem" class="w-full border p-2 mb-2">
                    </div>
                `).join('')}
                <button onclick="salvarAnuncios()" class="bg-green-600 text-white px-6 py-3 rounded font-bold">Salvar Anúncios</button>
            </div>
         `;
    }
}

// FUNÇÕES DE PRODUTO
function addSabor() {
    const div = document.createElement('div');
    div.className = "flex gap-2 mb-1";
    div.innerHTML = `
        <input placeholder="Nome" class="flex-1 border p-1">
        <input type="number" placeholder="Valor Extra" class="w-24 border p-1">
    `;
    document.getElementById('area_sabores').appendChild(div);
}

function addAdic() {
    const div = document.createElement('div');
    div.className = "flex gap-2 mb-1";
    div.innerHTML = `
        <input placeholder="Nome" class="flex-1 border p-1">
        <input type="number" placeholder="Preço" class="w-24 border p-1">
    `;
    document.getElementById('area_adicionais').appendChild(div);
}

function salvarConfig() {
    config.nome_loja = document.getElementById('nome_loja').value;
    config.cores.primaria = document.getElementById('cor1').value;
    config.cores.secundaria = document.getElementById('cor2').value;
    config.cores.fundo = document.getElementById('cor3').value;
    document.getElementById('code_config').value = JSON.stringify(config, null, 2);
}

function atualizarCodigoProdutos() {
    document.getElementById('code_prod').value = JSON.stringify(produtos, null, 2);
}

function copiar(id) {
    document.getElementById(id).select();
    document.execCommand('copy');
    alert("Copiado! Agora cole no arquivo correspondente do GitHub.");
}

// INICIA
carregar();
</script>
</body>
</html>
